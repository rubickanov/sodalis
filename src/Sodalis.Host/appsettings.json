{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Sodalis": "Host=localhost;Port=5432;Database=sodalis;Username=sodalis;Password=sodalis"
  },
  "Sodalis": {
    "Modules": {
      "Tenancy": {
        "Enabled": true,
        "SeedGames": [
          {
            "Id": "00000000-0000-0000-0000-000000000001",
            "Name": "Local Dev Game",
            "ApiKey": "sodalis_dev_localdevonly_replace_in_production_aaaaaaaaaaaaaaaa",
            "KeyLabel": "default"
          }
        ]
      },
      "Identity": {
        "Enabled": true,
        "Jwt": {
          "Issuer": "sodalis",
          "Audience": "sodalis",
          "SigningKey": "dev-only-signing-key-replace-in-production-min-32-bytes!!",
          "AccessTokenLifetimeMinutes": 15
        },
        "RefreshToken": {
          "LifetimeDays": 30
        }
      },
      "Profile": {
        "Enabled": true
      },
      "Messaging": {
        "Enabled": true,
        "Smtp": {
          "Host": "",
          "Port": 587,
          "Username": "",
          "Password": "",
          "UseStartTls": true,
          "FromAddress": "noreply@sodalis.dev",
          "FromName": "Sodalis"
        },
        "DefaultBranding": {
          "BrandName": "Sodalis",
          "ReplyTo": "support@sodalis.dev",
          "SupportUrl": "https://sodalis.dev/support",
          "LogoUrl": "",
          "PrimaryColor": "#2563eb",
          "FooterText": "© Sodalis"
        },
        "GameBranding": [
          {
            "GameId": "00000000-0000-0000-0000-000000000001",
            "BrandName": "Local Dev Game",
            "FromName": "Local Dev Game",
            "PrimaryColor": "#10b981"
          }
        ],
        "LinkBaseUrls": {
          "Verification": "http://localhost:5001/api/v1/auth/verify-email",
          "PasswordReset": "http://localhost:5001/auth/reset-password"
        },
        "TokenLifetimes": {
          "VerificationHours": 24,
          "PasswordResetMinutes": 60
        }
      }
    }
  }
}
