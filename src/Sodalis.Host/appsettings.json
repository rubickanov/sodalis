{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Sodalis": "Host=localhost;Port=5432;Database=sodalis;Username=sodalis;Password=sodalis"
  },
  "Sodalis": {
    "Modules": {
      "Identity": {
        "Enabled": true,
        "Jwt": {
          "Issuer": "sodalis",
          "Audience": "sodalis",
          "SigningKey": "dev-only-signing-key-replace-in-production-min-32-bytes!!",
          "AccessTokenLifetimeMinutes": 15
        },
        "RefreshToken": {
          "LifetimeDays": 30
        }
      },
      "Profile": {
        "Enabled": true
      }
    }
  }
}
